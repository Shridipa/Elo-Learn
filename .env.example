# Environment Configuration Template
# Copy to .env and fill in actual values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/elo_learn
REDIS_URL=redis://localhost:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=True

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ML Configuration
MODEL_CHECKPOINT_PATH=./checkpoints
DATA_PATH=./datasets
RESULTS_PATH=./results

# RL Configuration
RL_LEARNING_RATE=0.001
RL_GAMMA=0.99
RL_EPSILON_DECAY=0.995
RL_BUFFER_SIZE=100000

# Recommendation Configuration
REC_TOP_K=5
REC_BATCH_SIZE=32
REC_SIMILARITY_THRESHOLD=0.5

# Feature Engineering
EMBEDDING_DIM=64
STUDENT_EMBEDDING_DIM=32
CONCEPT_EMBEDDING_DIM=32

# Experiment Tracking
WANDB_PROJECT=elo-learn
WANDB_ENTITY=your_entity
WANDB_ENABLED=True

# Security
SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Email (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Performance
MAX_WORKERS=4
CACHE_TTL=3600
BATCH_SIZE=32

# System
TIMEZONE=UTC
LOCALE=en_US
