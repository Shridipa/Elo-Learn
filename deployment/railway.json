{
  "project": "elo-learn",
  "services": [
    {
      "name": "backend",
      "platform": "python",
      "build": {
        "install": "pip install -r requirements.txt"
      },
      "run": {
        "start": "uvicorn backend.main:app --host 0.0.0.0 --port $PORT"
      },
      "env": {
        "DATA_PATH": "/app/datasets",
        "RESULTS_PATH": "/app/results"
      }
    },
    {
      "name": "frontend",
      "platform": "python",
      "build": {
        "install": "pip install -r requirements.txt"
      },
      "run": {
        "start": "python -m streamlit run frontend/dashboard.py --server.port $PORT --server.headless true"
      }
    }
  ]
}
